{
  "expo": {
    "name": "Local Artist Finder",
    "slug": "local-artist-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "description": "Discover local EDM events and artists near you. Browse upcoming shows, listen to artist previews, and get tickets to events in your area.",
    "privacy": "public",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.discovery.localartist",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to find local events near you.",
        "NSContactsUsageDescription": "This app needs access to your contacts to help you find friends who are also using the app."
      },
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.discovery.localartist",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_CONTACTS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {},
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Local Artist Finder to use your location to find nearby events."
        }
      ],
      "expo-font",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin"
    ]
  }
}
