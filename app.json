{
  "expo": {
    "name": "drops",
    "slug": "drops",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "description": "drops - Discover the freshest EDM events and artists. Dive into the scene, explore genres, and catch the next drop.",
    "platforms": [
      "ios",
      "android"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.discovery.localartist",
      "buildNumber": "1",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "drops uses your location to find the freshest events near you.",
        "NSCameraUsageDescription": "drops needs camera access to scan QR codes and connect with other ravers.",
        "NFCReaderUsageDescription": "drops uses NFC to quickly connect with other ravers and check vibe compatibility."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.localartistfinder.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "NFC",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.NFC"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {},
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow drops to use your location to find nearby events."
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-audio",
      "react-native-nfc-manager",
      "expo-asset"
    ],
    "scheme": "drops",
    "extra": {
      "eas": {
        "projectId": "0120b233-a48a-46bf-91bb-d92087a4e145"
      }
    }
  }
}
